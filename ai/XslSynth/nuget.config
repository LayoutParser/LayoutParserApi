<?xml version="1.0" encoding="utf-8"?>
<!--
  Config de restore escopada ao gerador via Excel (ai/XslSynth).
  O DocumentFormat.OpenXml está no nuget.org público; o feed privado da
  organização (CENTRAL TFS) exige auth e retorna 401 neste ambiente,
  abortando o restore. Aqui limitamos as fontes ao nuget.org para o
  projeto restaurar de forma reprodutível. NÃO contém segredos.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
